{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@tokutei-ginou/shared": ["packages/shared/src"],
      "@tokutei-ginou/db": ["packages/db/src"]
    }
  },
  "include": ["apps/api/src"]
}
